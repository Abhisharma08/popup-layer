## Docker Compose (production-ish) example
## Copy to `.env` and fill values, then run: `docker compose up -d --build`

# Postgres
POSTGRES_PASSWORD="replace-with-a-strong-password"

# Backend
JWT_SECRET="replace-with-a-long-random-secret"
ALLOW_SIGNUP="false"
FRONTEND_URL="https://app.yourdomain.com"
PUBLIC_API_URL="https://api.yourdomain.com/api"
PUBLIC_EMBED_URL="https://api.yourdomain.com/embed/poplayer.iife.js"

# Frontend build args
VITE_API_URL="https://api.yourdomain.com/api"
VITE_EMBED_URL="https://api.yourdomain.com/embed/poplayer.iife.js"
