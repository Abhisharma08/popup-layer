generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String?
  createdAt    DateTime    @default(now())
  workspaces   Workspace[]
  memberships  WorkspaceMember[]
}

model Workspace {
  id        String   @id @default(uuid())
  userId    String   // Owner
  user      User     @relation(fields: [userId], references: [id])
  name      String
  siteId    String   @unique @default(cuid())
  domain    String?
  createdAt DateTime @default(now())
  popups    Popup[]
  members   WorkspaceMember[]
  domains   WorkspaceDomain[]

  @@index([userId])
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("MEMBER") // ADMIN, MEMBER
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceDomain {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  domain      String
  verified    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, domain])
  @@index([domain])
}

model Popup {
  id            String      @id @default(uuid())
  workspaceId   String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  type          String      // EMAIL_CAPTURE, ANNOUNCEMENT, EXIT_INTENT, COUPON
  status        String      @default("DRAFT") // DRAFT, ACTIVE, PAUSED
  config        String      // JSON stringified config (Variant A)
  triggers      String      // JSON stringified triggers (Variant A)
  webhookUrl    String?     // URL to POST leads to
  abTestEnabled Boolean     @default(false)
  configB       String?     // JSON stringified config (Variant B)
  triggersB     String?     // JSON stringified triggers (Variant B)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  leads         Lead[]
  events        AnalyticsEvent[]
  webhookDeliveries WebhookDelivery[]

  @@index([workspaceId])
  @@index([workspaceId, status])
}

model Lead {
  id        String   @id @default(uuid())
  popupId   String
  popup     Popup    @relation(fields: [popupId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  phone     String?
  sourceUrl String?
  customData String? // JSON string of custom form fields
  variant   String   @default("A") // "A" or "B"
  createdAt DateTime @default(now())
  webhookDeliveries WebhookDelivery[]

  @@unique([popupId, email])
  @@index([popupId, createdAt])
}

model AnalyticsEvent {
  id        String     @id @default(uuid())
  popupId   String
  popup     Popup      @relation(fields: [popupId], references: [id], onDelete: Cascade)
  event     String     // VIEW, SUBMIT, CLOSE
  variant   String     @default("A") // "A" or "B"
  createdAt DateTime   @default(now())

  @@index([popupId, event, createdAt])
  @@index([popupId, createdAt])
}

model WebhookDelivery {
  id         String   @id @default(uuid())
  popupId    String
  popup      Popup    @relation(fields: [popupId], references: [id], onDelete: Cascade)
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  url        String
  status     String   @default("PENDING") // PENDING, SUCCESS, FAILED
  statusCode Int?
  attempts   Int      @default(1)
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([popupId, createdAt])
  @@index([leadId])
  @@index([status, createdAt])
}
